# Where the dashboard reads its data from.
#   local    - the cft monitor's API running on your own PC (default setup;
#              your data never leaves your machine)
#   supabase - a hosted Supabase project (legacy)
VITE_DATA_SOURCE=local

# LOCAL MODE ONLY.
# Base URL of the monitor's API. Leave EMPTY when the dashboard is bundled
# inside the exe (it's then served from the same origin).
# Set it when the dashboard is HOSTED (e.g. Vercel), so the page knows where on
# your machine to fetch from. Must match the monitor's CFT_API_PORT.
VITE_API_BASE=http://127.0.0.1:47113

# SUPABASE MODE ONLY (legacy). Anon/public key — never the service_role key,
# and only safe if row-level security is enabled on your tables.
# VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key
