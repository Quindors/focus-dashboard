# Build-time defaults for the hosted (Vercel) deploy.
# No secrets here: just which backend to read and where it lives.
#
# The dashboard reads from the cft monitor running on YOUR PC, so your data
# never leaves your machine. Override in Vercel's env settings if needed.
VITE_DATA_SOURCE=local
VITE_API_BASE=http://127.0.0.1:47113
